{
  "name": "criminalsquad",
  "version": "0.3.0",
  "description": "Multi-agent orchestration framework — create AI squads that work together",
  "type": "module",
  "bin": {
    "criminalsquad": "bin/criminalsquad.js"
  },
  "scripts": {
    "test": "node --import ./tests/test-setup.js --test tests/*.test.js",
    "lint": "eslint src/ bin/ tests/ scripts/",
    "verify": "node scripts/verify.mjs",
    "release": "node scripts/release.mjs",
    "build:ide": "node src/build-ide-templates.js",
    "build:dist": "node scripts/build-dist.mjs",
    "publish:dist": "bash scripts/publish-dist.sh",
    "version": "node -e \"require('fs').writeFileSync('templates/_criminalsquad/.criminalsquad-version', require('./package.json').version + '\\n')\"",
    "indexar-acervo": "node scripts/indexar-acervo.js",
    "indexar-skills": "node scripts/indexar-skills.js",
    "check:skills": "node scripts/check-skills.js",
    "audit:skills": "node scripts/audit-skill-quality.mjs",
    "check:skill-quality": "node scripts/audit-skill-quality.mjs --check",
    "migrate:skills:v5": "node scripts/migrate-skills-v5.mjs",
    "generate:skill-ui": "node scripts/generate-skill-openai-metadata.mjs",
    "check:skill-evals": "node scripts/check-skill-evals.mjs",
    "check:legal-authorities": "node scripts/check-legal-authorities.mjs",
    "validate:legal-output": "node scripts/validate-legal-output.mjs",
    "calculo:fracao": "node scripts/legal-calculators/fraction-date-engine.mjs",
    "calculo:remicao": "node scripts/legal-calculators/remission-engine.mjs",
    "calculo:prescricao-executoria": "node scripts/legal-calculators/executory-limitation-engine.mjs",
    "eval:resumo": "node scripts/eval-resumo.mjs",
    "prazos:hoje": "node scripts/orchestra/prazos-hoje.mjs",
    "prazos:semana": "node scripts/orchestra/prazos-semana.mjs",
    "intimacoes": "node scripts/orchestra/intimacoes-recentes.mjs",
    "carteira": "node scripts/orchestra/carteira-consolidar.mjs",
    "carteira:metricas": "node scripts/orchestra/carteira-metricas.mjs"
  },
  "keywords": [
    "claude-code",
    "ai-agents",
    "multi-agent",
    "orchestration",
    "squads"
  ],
  "author": "Criminal Lab",
  "homepage": "https://github.com/bbpropulse/criminalsquad#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bbpropulse/criminalsquad.git"
  },
  "bugs": {
    "url": "https://github.com/bbpropulse/criminalsquad/issues"
  },
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "bin/",
    "src/",
    "scripts/",
    "skills/",
    "templates/_criminalsquad/",
    "templates/acervo/",
    "templates/ide-templates/",
    "templates/scripts/",
    "templates/squads/",
    "templates/package.json",
    "_criminalsquad/core/",
    "_criminalsquad/config/",
    "dashboard/"
  ],
  "dependencies": {
    "@inquirer/checkbox": "^5.1.0",
    "@inquirer/input": "^5.0.0",
    "@inquirer/select": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "globals": "^17.4.0"
  }
}
